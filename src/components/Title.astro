---
import type { HTMLTag } from 'astro/types';
import { Image } from 'astro:assets';
import star from '../images/star.webp';

interface Props {
    headingLevel: string;
    headingText: string;
    id?: string;
    tabindex?: string;
}

const { headingLevel, headingText, id, tabindex } = Astro.props;
const HeadingElement = `h${headingLevel}` as HTMLTag;
---

<HeadingElement class:list={['title']} id={id} tabindex={tabindex}>
    <Image src={star} alt=""/>
    <span>{headingText}</span>
</HeadingElement>

<style>
    .title {
        align-items: center;
        display: flex;
        gap: var(--gutter-s);
        inline-size: fit-content;
        margin-inline: auto;

        img {
            animation: rotate linear both;
            animation-duration: 1ms;
            animation-timeline: scroll(block root);
            aspect-ratio: 1;
            width: 1.25em;
        }
    }

    @keyframes rotate {
        0% {
            transform: rotate(0deg) scale(1);
        }

        100% {
            transform: rotate(360deg) scale(1.25);
        }
    }
</style>
